# ==========================================================
# PRECY+ SISTEMAS — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ==========================================================

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── Stripe ────────────────────────────────────────────────
# Chave pública (frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Chave secreta (backend) — NUNCA expor no frontend
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — gerado no painel Stripe
# stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — criados no painel Stripe
# Stripe Dashboard → Products → Add product → Add price
STRIPE_PRICE_ID_BASIC=price_...    # R$17/mês - Basic
STRIPE_PRICE_ID_PRO=price_...      # R$47/mês - Pro

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Precy+ Sistemas
NEXT_PUBLIC_APP_URL=https://precyplus.com.br

# ── Modo demo (não usar em produção) ──────────────────────
NEXT_PUBLIC_DEMO_MODE=false

# ── Catálogo Online: InfinityPay (pagamento) ──────────────
# Enquanto não houver credenciais, deixe INFINITYPAY_MODE=mock
# (ou simplesmente não defina INFINITYPAY_API_KEY) — o checkout
# funciona com aprovação simulada para testes.
INFINITYPAY_MODE=mock
INFINITYPAY_API_KEY=
INFINITYPAY_WEBHOOK_SECRET=
INFINITYPAY_BASE_URL=https://api.infinitepay.io

# ── Catálogo Online: SuperFrete (frete) ───────────────────
# Mesma lógica: sem SUPERFRETE_API_KEY, usa cálculo simulado.
SUPERFRETE_MODE=mock
SUPERFRETE_API_KEY=
SUPERFRETE_ORIGIN_CEP=
SUPERFRETE_BASE_URL=https://api.superfrete.com
